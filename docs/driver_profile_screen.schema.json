{
  "screenId": "driver_profile_ip_usn_income",
  "screenTitle": "Профиль водителя такси (ИП, УСН Доходы)",
  "version": "1.0.0",
  "meta": {
    "entity": "driver_profile",
    "taxMode": "usn_income_6",
    "platforms": ["web", "mobile"]
  },
  "globalStates": ["loading", "loaded", "empty", "error"],
  "profileStates": ["active", "pending_verification", "blocked"],
  "sections": [
    {
      "id": "profile_header",
      "component": "ProfileHeader",
      "position": 1,
      "states": ["default"],
      "fields": [
        { "key": "avatarUrl", "type": "image", "required": false },
        { "key": "fullName", "type": "string", "required": true },
        { "key": "role", "type": "string", "required": true, "default": "Водитель такси" },
        { "key": "businessForm", "type": "string", "required": true, "default": "ИП" },
        { "key": "taxMode", "type": "string", "required": true, "default": "УСН Доходы" },
        { "key": "accountStatus", "type": "enum", "required": true, "enum": ["active", "pending_verification", "blocked"] }
      ],
      "actions": [
        { "id": "change_avatar", "label": "Сменить аватар", "type": "open_file_uploader" }
      ]
    },
    {
      "id": "quick_statuses",
      "component": "ProfileStatusCardGroup",
      "position": 2,
      "items": [
        {
          "id": "documents_status",
          "component": "ProfileStatusCard",
          "states": ["ok", "warning", "error"],
          "data": { "confirmed": 8, "total": 8 }
        },
        {
          "id": "taxi_permit_status",
          "component": "ProfileStatusCard",
          "states": ["active", "expiring_soon", "expired", "missing"]
        },
        {
          "id": "payout_status",
          "component": "ProfileStatusCard",
          "states": ["connected", "pending", "disabled"]
        },
        {
          "id": "insurance_status",
          "component": "ProfileStatusCard",
          "states": ["valid", "expiring_soon", "expired"],
          "fields": [{ "key": "validUntil", "type": "date" }]
        }
      ]
    },
    {
      "id": "profile_tabs",
      "component": "ProfileTabs",
      "position": 3,
      "behavior": {
        "switchWithoutReload": true,
        "persistLastTab": true
      },
      "tabs": [
        { "id": "overview", "label": "Обзор", "component": "OverviewStats" },
        { "id": "taxi_ip", "label": "Такси / ИП", "component": "TaxiIpInfoCard" },
        { "id": "documents", "label": "Документы", "component": "DocumentList", "states": ["active", "inactive", "attention"] },
        { "id": "payouts", "label": "Выплаты", "component": "PayoutCard" },
        { "id": "security", "label": "Безопасность", "component": "SecuritySettingsList" }
      ]
    },
    {
      "id": "tab_content",
      "component": "ContentContainer",
      "position": 4,
      "states": ["loading", "loaded", "empty", "error"],
      "tabSchemas": {
        "overview": {
          "blocks": [
            { "id": "rating", "component": "StatCard", "field": "rating" },
            { "id": "city_zone", "component": "InfoRow", "fields": ["city", "workZone"] },
            { "id": "vehicle", "component": "InfoCard", "fields": ["carBrand", "carModel", "plateNumber"] },
            { "id": "rides_count", "component": "StatCard", "field": "ridesTotal" },
            { "id": "income_day", "component": "StatCard", "field": "incomeDay" },
            { "id": "income_week", "component": "StatCard", "field": "incomeWeek" }
          ]
        },
        "taxi_ip": {
          "blocks": [
            { "id": "inn", "component": "DataRow", "state": ["filled", "empty"] },
            { "id": "ogrnip", "component": "DataRow", "state": ["filled", "empty"] },
            { "id": "ip_registration_date", "component": "DataRow", "state": ["filled", "empty"] },
            { "id": "tax_mode", "component": "DataRow", "value": "УСН Доходы 6%" },
            { "id": "taxi_permit", "component": "DataCard", "state": ["active", "expiring_soon", "expired", "empty"] },
            { "id": "region", "component": "DataRow" },
            { "id": "vehicle_data", "component": "DataCard", "state": ["filled", "partial", "empty"] },
            { "id": "driver_license", "component": "DataCard", "state": ["valid", "expiring_soon", "expired"] }
          ]
        },
        "documents": {
          "blocks": [
            {
              "id": "documents_list",
              "component": "DocumentList",
              "states": ["loaded", "empty"],
              "itemComponent": "DocumentItem",
              "itemFields": ["name", "uploadedAt", "validUntil", "reviewStatus"],
              "itemStates": ["uploaded", "checking", "approved", "rejected", "expired"]
            }
          ],
          "actions": [
            { "id": "upload_document", "label": "Загрузить документ", "type": "open_file_uploader", "style": "primary" },
            { "id": "replace_document", "label": "Заменить документ", "type": "replace_file", "style": "secondary" },
            { "id": "open_document", "label": "Открыть документ", "type": "open_file_preview", "style": "tertiary" },
            { "id": "delete_document", "label": "Удалить документ", "type": "delete_with_confirm", "style": "destructive" }
          ]
        },
        "payouts": {
          "blocks": [
            { "id": "requisites", "component": "PayoutCard", "state": ["filled", "partial", "empty"] },
            { "id": "payout_history", "component": "ListTable", "state": ["loaded", "empty"] },
            { "id": "income_day", "component": "StatCard" },
            { "id": "income_week", "component": "StatCard" },
            { "id": "income_month", "component": "StatCard" },
            { "id": "tax_reserve", "component": "TaxReserveCard", "state": ["default", "warning"] },
            { "id": "usn_hint", "component": "InfoBanner", "state": ["default"] }
          ],
          "actions": [
            { "id": "download_report", "label": "Скачать отчёт", "type": "download_report", "states": ["default", "loading"] },
            { "id": "open_payouts", "label": "Открыть выплаты", "type": "navigate_payouts", "style": "primary" }
          ]
        },
        "security": {
          "blocks": [
            { "id": "phone_verification", "component": "SettingsRow", "state": ["verified", "unverified"] },
            { "id": "email_verification", "component": "SettingsRow", "state": ["verified", "unverified"] },
            { "id": "two_factor", "component": "ToggleRow", "state": ["enabled", "disabled"] },
            { "id": "active_devices", "component": "List", "state": ["loaded", "empty"] },
            { "id": "login_history", "component": "List", "state": ["loaded", "empty"] }
          ],
          "actions": [
            { "id": "change_password", "label": "Сменить пароль", "type": "open_change_password_form" },
            { "id": "terminate_all_sessions", "label": "Завершить все сессии", "type": "terminate_all_sessions_with_confirm", "style": "destructive" }
          ]
        }
      }
    },
    {
      "id": "sticky_action_bar",
      "component": "StickyActionBar",
      "position": 5,
      "states": ["visible", "hidden"],
      "defaultActions": [
        { "id": "edit_profile", "label": "Редактировать профиль", "type": "open_profile_edit", "style": "primary" },
        { "id": "upload_document", "label": "Загрузить документ", "type": "open_file_uploader", "style": "secondary" },
        { "id": "open_payouts", "label": "Открыть выплаты", "type": "navigate_payouts", "style": "secondary" },
        { "id": "open_security", "label": "Настройки безопасности", "type": "switch_tab", "targetTab": "security", "style": "secondary" }
      ],
      "tabOverrides": {
        "documents": ["upload_document"],
        "payouts": ["open_payouts", "download_report"],
        "security": ["open_security", "change_password", "terminate_all_sessions"]
      }
    }
  ],
  "events": [
    { "id": "tab_click", "effect": "switch_active_tab" },
    { "id": "edit_profile_click", "effect": "open_profile_edit_form" },
    { "id": "upload_document_click", "effect": "open_file_uploader" },
    { "id": "document_item_click", "effect": "open_document_details" },
    { "id": "replace_document_click", "effect": "upload_new_document_version" },
    { "id": "delete_document_click", "effect": "open_delete_confirm_modal" },
    { "id": "open_payouts_click", "effect": "navigate_to_payout_section" },
    { "id": "toggle_2fa", "effect": "update_2fa_state" },
    { "id": "api_error", "effect": "show_error_banner_or_state" }
  ],
  "responsiveRules": {
    "mobile": {
      "quickStatusesLayout": "grid_2_rows",
      "tabs": "horizontal_scroll",
      "stickyActionBar": "fixed_bottom"
    },
    "desktop": {
      "quickStatusesLayout": "single_row",
      "tabs": "under_header",
      "actionsPlacement": ["right_panel", "bottom_content"]
    }
  }
}
