# Telegram bot token from BotFather (required)
BOT_TOKEN=123456:replace_with_real_bot_token

# Chat ID for moderation/admin messages (required, integer)
ADMIN_CHAT_ID=-1001234567890

# Target chat ID where approved posts are published (required, integer)
GROUP_CHAT_ID=-1009876543210

# Optional comma-separated Telegram user IDs with moderation rights
ADMIN_IDS=123456789,987654321

# Optional HTTP API host and port
FEED_API_HOST=0.0.0.0
FEED_API_PORT=8001

# Optional path to SQLite DB file
BAZAR_DB_PATH=bot.db

# Optional directory for uploaded feed images
FEED_UPLOAD_DIR=storage/feed_images
